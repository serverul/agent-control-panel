# Agent Control Panel Configuration
# Copy this to .env and customize

# Ports
ACP_PORT=3101          # Frontend
ACP_API_PORT=3100      # Backend API
ACP_DB_PORT=5433       # PostgreSQL

# Auth (change these!)
ACP_ADMIN_USER=admin
ACP_ADMIN_PASS=admin123
ACP_SECRET_KEY=change-me-to-a-random-secret

# Database (internal)
POSTGRES_USER=acp
POSTGRES_PASSWORD=acp_secret
POSTGRES_DB=agent_control_panel
